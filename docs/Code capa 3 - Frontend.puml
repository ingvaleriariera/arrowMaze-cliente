@startuml client_layer3_adapters
title Arrow Maze Cliente — Capa 3: Interface Adapters

skinparam backgroundColor #FFFFFF
skinparam class {
  BackgroundColor #FCE4EC
  BorderColor #C62828
  HeaderBackgroundColor #E53935
  HeaderFontColor #FFFFFF
  FontColor #000000
  ArrowColor #333333
}
skinparam interface {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  HeaderBackgroundColor #1E88E5
  HeaderFontColor #FFFFFF
}
skinparam note {
  BackgroundColor #F3E5F5
  BorderColor #7B1FA2
}

note as N1
  Capa 3 tiene dos responsabilidades:
  1. StateNotifiers (Riverpod) = Presenters:
     puente entre la UI (C4) y los
     casos de uso (C2). Guardan el estado.
  2. Implementaciones de repositorios = Adapters:
     conectan los puertos de C1 y C2
     con los frameworks de C4 (sqflite,
     shared_preferences, HTTP, secure storage).
end note

' ─────────────────────────────────────────
' STATE NOTIFIERS — Presenters / ViewModels
' ─────────────────────────────────────────

class GameNotifier <<StateNotifier>> {
  - session: GameSession?
  - progress: GameProgress?
  - timer: Timer?
  - userId: String?
  - loadLevelUseCase: LoadLevelUseCase
  - activateArrowUseCase: ActivateArrowUseCase
  - pauseLevelUseCase: PauseLevelUseCase
  - resumeLevelUseCase: ResumeLevelUseCase
  - restartLevelUseCase: RestartLevelUseCase
  - usePowerUpUseCase: UsePowerUpUseCase
  - saveProgressUseCase: SaveProgressUseCase
  - getLocalProgressUseCase: GetLocalProgressUseCase
  - preloadLevelsUseCase: PreloadLevelsUseCase
  - submitScoreUseCase: SubmitScoreUseCase
  - getVibrationEnabled: bool Function()
  - audioObserver: IGameObserver
  - audioService: IAudioService
  --
  + loadLevel(levelId: String, userId: String): void
  + activateArrow(arrowId: String): void
  + usePowerUp(powerUp: PowerUp): PowerUpResult?
  + pause(): void
  + resume(): void
  + restart(levelId: String, userId: String): void
  + stopTimer(): void
  - _startTimer(): void
  - _stopTimer(): void
  - _handleSessionOverIfNeeded(): void
  - _nextLevelIds(levelId: String, count: int): List<String>
  - _triggerHaptic(hapticCall: Function): void
}

note right of GameNotifier
  startTimer() crea un Timer.periodic
  (dart:async, C4) que llama
  session.tick() cada segundo.
  loadLevel() suscribe audioObserver a la
  GameSession (Patrón Observer, C1/C3) y
  dispara preloadLevelsUseCase en segundo
  plano para los próximos 2 niveles.
  _handleSessionOverIfNeeded() persiste
  progreso y envía el score al leaderboard
  — salvo en tableros custom (free play).
end note

class AuthNotifier <<StateNotifier>> {
  - loginUseCase: LoginUseCase
  - registerUseCase: RegisterUseCase
  - logoutUseCase: LogoutUseCase
  - syncProgressUseCase: SyncProgressUseCase
  - faceIdLoginUseCase: FaceIdLoginUseCase
  - faceIdLoginWithEmailUseCase: FaceIdLoginWithEmailUseCase
  --
  + login(emailOrUsername: String, password: String): void
  + loginWithFaceId(): void
  + loginWithFaceIdAndEmail(email: String): void
  + register(email: String, username: String, password: String): void
  + logout(): void
  + checkAuth(): void
  + clearError(): void
}

note right of AuthNotifier
  login()/register()/loginWithFaceId*()
  actualizan el estado de inmediato y
  disparan syncProgressUseCase en background
  (no bloqueante: un fallo de sync no
  deslogea al usuario).
end note

class LevelSelectNotifier <<StateNotifier>> {
  - getLevelSummariesUseCase: GetLevelSummariesUseCase
  - preloadLevelsUseCase: PreloadLevelsUseCase
  - manageMyBoardsUseCase: ManageMyBoardsUseCase
  - audioService: IAudioService
  --
  + loadSummaries(userId: String): void
  + preloadAllLevels(): void
}

note right of LevelSelectNotifier
  loadSummaries() combina niveles estándar
  con los tableros custom adoptados
  (manageMyBoardsUseCase), usando
  CustomAwareLevelRepository.levelIdFor()
  para generar sus ids "custom-...".
end note

class LeaderboardNotifier <<StateNotifier>> {
  - getLeaderboardUseCase: GetLeaderboardUseCase
  - getGlobalLeaderboardUseCase: GetGlobalLeaderboardUseCase
  --
  + loadLeaderboard(levelId: String): void
  + loadGlobalLeaderboard(): void
}

class SettingsNotifier <<StateNotifier>> {
  - audioService: IAudioService
  --
  + toggleMute(): void
  + toggleVibration(): void
  + toggleBoard3D(): void
  + toggleGame3D(): void
}

class BoardsNotifier <<StateNotifier>> {
  - getCommunityBoardsUseCase: GetCommunityBoardsUseCase
  - manageMyBoardsUseCase: ManageMyBoardsUseCase
  - createCustomBoardUseCase: CreateCustomBoardUseCase
  - deleteCustomBoardUseCase: DeleteCustomBoardUseCase
  --
  + loadAll(): void
  + deleteOwn(boardId: String): bool
  + adopt(board: CustomBoardDTO): void
  + removeFromMine(boardId: String): void
  + create(name: String, difficulty: String, grid: List<List<int>>): bool
}

note right of BoardsNotifier
  Presenter del editor de tableros de la
  comunidad. loadAll() carga primero "Míos"
  (nunca depende de red) y luego sana copias
  locales obsoletas con datos frescos del
  servidor (autorUsername/authorId).
end note

class LivesNotifier <<StateNotifier>> {
  - getLivesUseCase: GetLivesUseCase
  - loseLifeUseCase: LoseLifeUseCase
  - buyLifeUseCase: BuyLifeUseCase
  - userId: String?
  - ticker: Timer?
  --
  + load(userId: String): void
  + loseLife(): void
  + buyLife(): bool
  - _emit(lives: PlayerLives): void
  - _syncTicker(lives: PlayerLives): void
}

note right of LivesNotifier
  Único dueño de toda mutación de vidas.
  _syncTicker() corre un Timer.periodic
  de 1s (solo mientras el pool no está
  lleno) para refrescar la cuenta regresiva
  y disparar la regeneración cuando vence.
end note

class LocaleNotifier <<StateNotifier>> {
  --
  + setLocale(locale: Locale): void
  + toggleLanguage(): void
}

' ─────────────────────────────────────────
' FACADE — ApiClient
' ─────────────────────────────────────────

class ApiClient <<Facade>> {
  - baseUrl: String
  - token: String?
  --
  + setToken(token: String): void
  + clearToken(): void
  + addInterceptor(interceptor: Interceptor): void
  + get(path: String): Map
  + post(path: String, body: Map): Map
  + put(path: String, body: Map): Map
  + delete(path: String): void
}

note right of ApiClient
  Patrón Facade (Estructural).
  Simplifica el acceso HTTP a todos
  los endpoints del backend con Dio (C4).
  addInterceptor() es el punto de enganche
  de los aspectos AOP de Capa 4
  (Auth/Logging/Error interceptors).
  Todos los repositorios remotos
  lo usan como único punto de acceso.
end note

' ─────────────────────────────────────────
' REPOSITORY IMPLEMENTATIONS — Adapters
' ─────────────────────────────────────────

class LevelRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  - levelMapper: LevelMapper
  - levelsCache: List<Level>?
  --
  + getLevel(levelId: String): Level
  + getLevels(): List<Level>
  + getLevelsByDifficulty(difficulty: String): List<Level>
}

note bottom of LevelRepositoryImpl
  Implementa ILevelRepository (C1).
  Llama al backend vía ApiClient y
  convierte JSON → Level con LevelMapper.
  El backend no expone GET /levels/:id,
  así que getLevel() cachea la lista
  completa y filtra en memoria.
end note

class CustomAwareLevelRepository <<Decorator>> {
  - inner: ILevelRepository
  - myBoards: IMyBoardsRepository
  --
  + {static} levelIdFor(boardId: String): String
  + {static} isCustomLevelId(levelId: String): bool
  + getLevel(levelId: String): Level
  + getLevels(): List<Level>
  + getLevelsByDifficulty(difficulty: String): List<Level>
}

note bottom of CustomAwareLevelRepository
  Patrón Decorator (Estructural).
  Envuelve ILevelRepository: ids con prefijo
  "custom-" se resuelven contra los tableros
  adoptados localmente (myBoards) y se
  adaptan a un Level normal; todo lo demás
  se delega sin tocar al repositorio interno.
  Es el proveedor real de levelRepositoryProvider
  (providers.dart) — el pipeline de juego
  nunca distingue tableros de jugadores.
end note

class GameProgressRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  - progressMapper: ProgressMapper
  - database: IGameProgressLocalStore
  - localCache: Map<String, GameProgress>
  --
  + save(progress: GameProgress): void
  + get(userId: String): GameProgress?
  + sync(userId: String): GameProgress
  - _reconstructProgressFromDatabase(dbRecord: Map, userId: String): GameProgress
}

note bottom of GameProgressRepositoryImpl
  Implementa IGameProgressRepository (C1).
  save()/get() → cache en memoria +
  IGameProgressLocalStore (sqflite en móvil,
  shared_preferences en Web — ver providers.dart).
  sync() → compara local con backend vía
  ApiClient; last-write-wins para niveles,
  max(local, servidor) como resguardo de coins.
end note

class AuthRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  - secureStorage: FlutterSecureStorage
  --
  + login(email: String, password: String): AuthResultDTO
  + register(email: String, username: String, password: String): AuthResultDTO
  + logout(): void
  + getToken(): String?
  + isAuthenticated(): bool
  + saveBiometricCredentials(email: String, password: String): void
  + getBiometricCredentials(): (String, String)?
  + hasSavedBiometricCredentials(): bool
  + hasSavedCredentialsForEmail(email: String): bool
}

note bottom of AuthRepositoryImpl
  Implementa IAuthRepository (C2).
  Llama /auth/login y /auth/register vía
  ApiClient. Persiste JWT y credenciales
  para Face ID con flutter_secure_storage (C4).
  logout() borra el token pero conserva las
  credenciales biométricas para el siguiente login.
end note

class LeaderboardRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  --
  + getTopScores(levelId: String, limit: int): List<LeaderboardEntryDTO>
  + getGlobalTopScores(limit: int): List<GlobalLeaderboardEntryDTO>
}

note bottom of LeaderboardRepositoryImpl
  Implementa ILeaderboardRepository (C2).
  Llama /leaderboard/{levelId} y
  /leaderboard/global vía ApiClient.
end note

class ScoreRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  --
  + submitScore(userId: String, levelId: String, score: int): void
}

note bottom of ScoreRepositoryImpl
  Implementa IScoreRepository (C2).
  Llama POST /scores/submit vía ApiClient.
  Alimenta el leaderboard por nivel,
  separado del progreso sincronizado.
end note

class CustomBoardRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  --
  + create(name: String, difficulty: String, boardLayout: String): CustomBoardDTO
  + fetchAll(limit: int): List<CustomBoardDTO>
  + delete(id: String): void
}

note bottom of CustomBoardRepositoryImpl
  Implementa ICustomBoardRepository (C2).
  CRUD de tableros de la comunidad contra
  /api/v1/custom-boards vía ApiClient.
end note

class MyBoardsRepositoryImpl <<Adapter>> {
  --
  + getAll(): List<CustomBoardDTO>
  + getById(id: String): CustomBoardDTO?
  + add(board: CustomBoardDTO): void
  + remove(id: String): void
}

note bottom of MyBoardsRepositoryImpl
  Implementa IMyBoardsRepository (C2).
  Copia local de tableros adoptados en
  SharedPreferences (C4), device-wide
  (no por usuario) — jugable offline.
end note

class LivesRepositoryImpl <<Adapter>> {
  --
  + load(userId: String): PlayerLives
  + save(userId: String, lives: PlayerLives): void
}

note bottom of LivesRepositoryImpl
  Implementa ILivesRepository (C1).
  Persiste el pool de vidas en
  SharedPreferences (C4), por usuario,
  deliberadamente fuera del sync de progreso.
end note

class AudioServiceImpl <<Adapter, Singleton>> {
  - isMuted: bool
  - currentMusicTrack: String?
  - lastRequestedTrack: String?
  --
  + playEffect(sound: String): void
  + playMusic(track: String): void
  + stopMusic(): void
  + mute(): void
  + unmute(): void
  + isMuted(): bool
  + dispose(): void
}

note bottom of AudioServiceImpl
  Implementa IAudioService (C2).
  Patrón Singleton (Creacional): constructor
  factory + instancia estática — un solo par
  de AudioPlayers (música/efectos) en toda la app.
  Usa just_audio (C4). lastRequestedTrack permite
  reintentar la música en unmute() cuando el
  navegador bloqueó el autoplay inicial (Web).
end note

class GameProgressDatabase <<Adapter, Singleton>> {
  --
  + getProgress(userId: String): Map?
  + saveProgress(userId: String, completedLevels: List<String>, bestScores: Map<String,int>, coins: int, avatarEmoji: String): void
  + deleteProgress(userId: String): void
  + closeDatabase(): void
}

note bottom of GameProgressDatabase
  Implementa IGameProgressLocalStore.
  Patrón Singleton (Creacional): constructor
  factory + instancia estática — una sola
  conexión sqflite (C4) por proceso.
  Backend de GameProgressRepositoryImpl
  en plataformas móviles.
end note

class WebGameProgressStore <<Adapter>> {
  - prefs: SharedPreferences
  --
  + getProgress(userId: String): Map?
  + saveProgress(userId: String, completedLevels: List<String>, bestScores: Map<String,int>, coins: int, avatarEmoji: String): void
  + deleteProgress(userId: String): void
  + closeDatabase(): void
}

note bottom of WebGameProgressStore
  Implementa IGameProgressLocalStore.
  Contraparte Web de GameProgressDatabase:
  sqflite no corre en Flutter Web, así que
  este adapter persiste la misma forma de
  fila en SharedPreferences (localStorage, C4).
  Elegido en runtime por providers.dart
  según kIsWeb (Patrón Strategy).
end note

class InMemoryBoardCache <<Adapter>> {
  - layouts: Map<String, List<Arrow>>
  --
  + has(levelId: String): bool
  + put(levelId: String, arrows: List<Arrow>): void
  + get(levelId: String): List<Arrow>?
}

note bottom of InMemoryBoardCache
  Implementa IBoardCache (C1).
  Cachea tableros generados procedimentalmente
  (compartido por LoadLevelUseCase y
  PreloadLevelsUseCase, C2). Vive solo mientras
  dura el proceso: el seed determinístico hace
  innecesaria la persistencia entre reinicios.
end note

class AudioObserver <<Adapter, Observer>> {
  - audioService: IAudioService
  --
  + onPlayerMoved(result: MoveResult): void
  + onScoreUpdated(newScore: int): void
  + onLevelCompleted(success: bool, finalScore: int): void
}

note bottom of AudioObserver
  Implementa IGameObserver (C1).
  Patrón Observer (Comportamiento):
  GameSession (C1, Subject) notifica eventos
  de juego; AudioObserver (Listener concreto)
  reacciona deteniendo la música y reproduciendo
  el efecto de victoria/derrota — el dominio
  del juego no sabe que el audio existe.
end note

' ─────────────────────────────────────────
' PUERTO INTERNO DE ADAPTERS
' ─────────────────────────────────────────

interface IGameProgressLocalStore {
  + getProgress(userId: String): Map?
  + saveProgress(userId: String, completedLevels: List<String>, bestScores: Map<String,int>, coins: int, avatarEmoji: String): void
  + deleteProgress(userId: String): void
  + closeDatabase(): void
}

note right of IGameProgressLocalStore
  Puerto propio de Capa 3 (no C1/C2):
  abstrae el backend de almacenamiento local
  detrás de GameProgressRepositoryImpl,
  para que sqflite y shared_preferences
  sean intercambiables sin tocar la lógica
  de cache/sync que corre por encima.
end note

' ─────────────────────────────────────────
' MAPPERS
' ─────────────────────────────────────────

class LevelMapper {
  --
  + fromJson(json: Map): Level
  + fromJsonList(jsonList: List): List<Level>
  + arrowFromJson(json: Map): Arrow
  - _parseDirection(directionStr: String): Direction
}

class ProgressMapper {
  --
  + fromMap(map: Map, userId: String): GameProgress
  + toMap(progress: GameProgress): Map
}

note right of ProgressMapper
  fromMap() → convierte la respuesta de
  /progress/sync (o fila local) a GameProgress.
  toMap()   → convierte GameProgress al body
  esperado por el backend. avatarEmoji nunca
  viaja por el backend: se preserva localmente.
end note

