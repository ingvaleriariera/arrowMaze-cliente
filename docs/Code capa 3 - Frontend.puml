@startuml client_layer3_adapters
title Arrow Maze Cliente — Capa 3: Interface Adapters

skinparam backgroundColor #FFFFFF
skinparam class {
  BackgroundColor #FCE4EC
  BorderColor #C62828
  HeaderBackgroundColor #E53935
  HeaderFontColor #FFFFFF
  FontColor #000000
  ArrowColor #333333
}
skinparam interface {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  HeaderBackgroundColor #1E88E5
  HeaderFontColor #FFFFFF
}
skinparam note {
  BackgroundColor #F3E5F5
  BorderColor #7B1FA2
}

note as N1
  Capa 3 tiene dos responsabilidades:
  1. StateNotifiers (Riverpod) = Presenters:
     puente entre la UI (C4) y los
     casos de uso (C2). Guardan el estado.
  2. Implementaciones de repositorios = Adapters:
     conectan los puertos de C1 y C2
     con los frameworks de C4 (sqflite, HTTP).
end note

' ─────────────────────────────────────────
' STATE NOTIFIERS — Presenters / ViewModels
' ─────────────────────────────────────────

class GameNotifier <<StateNotifier>> {
  - session: GameSession?
  - progress: GameProgress?
  - timer: Timer?
  - loadLevelUseCase: LoadLevelUseCase
  - activateArrowUseCase: ActivateArrowUseCase
  - pauseUseCase: PauseLevelUseCase
  - resumeUseCase: ResumeLevelUseCase
  - restartUseCase: RestartLevelUseCase
  - usePowerUpUseCase: UsePowerUpUseCase
  - saveProgressUseCase: SaveProgressUseCase
  - syncProgressUseCase: SyncProgressUseCase
  - getProgressUseCase: GetLocalProgressUseCase
  --
  + loadLevel(levelId: String): void
  + activateArrow(arrowId: String): void
  + useHint(): void
  + useHammer(arrowId: String): void
  + useMagnet(direction: Direction): void
  + pause(): void
  + resume(): void
  + restart(): void
  - startTimer(): void
  - stopTimer(): void
}

note right of GameNotifier
  startTimer() crea un Timer.periodic
  (dart:async, C4) que llama
  session.tick() cada segundo.
  stopTimer() lo cancela.
  useHint/Hammer/Magnet() instancian
  el PowerUp concreto y lo pasan a
  UsePowerUpUseCase.
end note

class AuthNotifier <<StateNotifier>> {
  - isAuthenticated: bool
  - userId: String?
  - loginUseCase: LoginUseCase
  - registerUseCase: RegisterUseCase
  - logoutUseCase: LogoutUseCase
  - syncProgressUseCase: SyncProgressUseCase
  --
  + login(email: String, password: String): void
  + register(email: String, username: String, password: String): void
  + logout(): void
  + getIsAuthenticated(): bool
  + getUserId(): String?
}

note right of AuthNotifier
  login() → tras autenticar, llama
  syncProgressUseCase.execute(userId)
  para traer el progreso del servidor
  y actualizar el local.
end note

class LevelSelectNotifier <<StateNotifier>> {
  - levels: List<LevelSummaryDTO>
  - getLevelSummariesUseCase: GetLevelSummariesUseCase
  --
  + loadSummaries(userId: String): void
  + getLevels(): List<LevelSummaryDTO>
}

class LeaderboardNotifier <<StateNotifier>> {
  - entries: List<LeaderboardEntryDTO>
  - getLeaderboardUseCase: GetLeaderboardUseCase
  --
  + loadLeaderboard(levelId: String): void
  + getEntries(): List<LeaderboardEntryDTO>
}

class SettingsNotifier <<StateNotifier>> {
  - isMuted: bool
  - audioService: IAudioService
  --
  + toggleMute(): void
  + getIsMuted(): bool
}

' ─────────────────────────────────────────
' FACADE — ApiClient
' ─────────────────────────────────────────

class ApiClient <<Facade>> {
  - baseUrl: String
  - token: String?
  --
  + setToken(token: String): void
  + clearToken(): void
  + get(path: String): Map
  + post(path: String, body: Map): Map
  + put(path: String, body: Map): Map
  + delete(path: String): void
}

note right of ApiClient
  Patrón Facade (Estructural).
  Simplifica el acceso HTTP a todos
  los endpoints del backend.
  Agrega el JWT header automáticamente
  en cada request.
  Oculta la complejidad de Dio (C4).
  Todos los repositorios remotos
  lo usan como único punto de acceso.
end note

' ─────────────────────────────────────────
' REPOSITORY IMPLEMENTATIONS — Adapters
' ─────────────────────────────────────────

class LevelRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  - levelMapper: LevelMapper
  --
  + getLevel(levelId: String): Level
  + getLevels(): List<Level>
  + getLevelsByDifficulty(difficulty: String): List<Level>
}

note bottom of LevelRepositoryImpl
  Implementa ILevelRepository (C1).
  Llama al backend vía ApiClient y
  convierte JSON → Level con LevelMapper.
end note

class GameProgressRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  - progressMapper: ProgressMapper
  --
  + save(progress: GameProgress): void
  + get(userId: String): GameProgress?
  + sync(userId: String): GameProgress
}

note bottom of GameProgressRepositoryImpl
  Implementa IGameProgressRepository (C1).
  save() y get() → sqflite (C4).
  sync() → compara local con backend
  vía ApiClient y resuelve conflictos
  (last-write-wins por defecto).
end note

class AuthRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  --
  + login(email: String, password: String): AuthResultDTO
  + register(email: String, username: String, password: String): AuthResultDTO
  + logout(): void
  + getToken(): String?
  + isAuthenticated(): bool
}

note bottom of AuthRepositoryImpl
  Implementa IAuthRepository (C2).
  Llama /auth/login y /auth/register
  vía ApiClient.
  Persiste el JWT con
  flutter_secure_storage (C4).
end note

class LeaderboardRepositoryImpl <<Adapter>> {
  - apiClient: ApiClient
  --
  + getTopScores(levelId: String, limit: int): List<LeaderboardEntryDTO>
}

note bottom of LeaderboardRepositoryImpl
  Implementa ILeaderboardRepository (C2).
  Llama /leaderboard/{levelId} vía ApiClient.
end note

class AudioServiceImpl <<Adapter>> {
  - isMuted: bool
  --
  + playEffect(sound: String): void
  + playMusic(track: String): void
  + stopMusic(): void
  + mute(): void
  + unmute(): void
  + isMuted(): bool
}

note bottom of AudioServiceImpl
  Implementa IAudioService (C2).
  Usa just_audio o audioplayers (C4).
  isMuted persiste en SharedPreferences (C4).
end note

' ─────────────────────────────────────────
' MAPPERS
' ─────────────────────────────────────────

class LevelMapper {
  --
  + fromJson(json: Map): Level
  + arrowFromJson(json: Map): Arrow
}

class ProgressMapper {
  --
  + fromMap(map: Map): GameProgress
  + toMap(progress: GameProgress): Map
}

note right of ProgressMapper
  fromMap() → convierte fila de sqflite a GameProgress.
  toMap()   → convierte GameProgress a fila para sqflite.
end note

' ─────────────────────────────────────────
' RELACIONES — StateNotifiers → Use Cases (C2)
' ─────────────────────────────────────────

GameNotifier --> LoadLevelUseCase       : uses (C2)
GameNotifier --> ActivateArrowUseCase   : uses (C2)
GameNotifier --> PauseLevelUseCase      : uses (C2)
GameNotifier --> ResumeLevelUseCase     : uses (C2)
GameNotifier --> RestartLevelUseCase    : uses (C2)
GameNotifier --> UsePowerUpUseCase      : uses (C2)
GameNotifier --> SaveProgressUseCase    : uses (C2)
GameNotifier --> SyncProgressUseCase    : uses (C2)
GameNotifier --> GetLocalProgressUseCase : uses (C2)

AuthNotifier      --> LoginUseCase          : uses (C2)
AuthNotifier      --> RegisterUseCase       : uses (C2)
AuthNotifier      --> LogoutUseCase         : uses (C2)
AuthNotifier      --> SyncProgressUseCase   : uses (C2)

LevelSelectNotifier --> GetLevelSummariesUseCase : uses (C2)
LeaderboardNotifier --> GetLeaderboardUseCase    : uses (C2)
SettingsNotifier    --> IAudioService            : uses (C2)

' ─────────────────────────────────────────
' RELACIONES — Implementations → Interfaces
' ─────────────────────────────────────────

LevelRepositoryImpl       ..|> ILevelRepository          : implements (C1)
GameProgressRepositoryImpl ..|> IGameProgressRepository   : implements (C1)
AuthRepositoryImpl         ..|> IAuthRepository           : implements (C2)
LeaderboardRepositoryImpl  ..|> ILeaderboardRepository    : implements (C2)
AudioServiceImpl           ..|> IAudioService             : implements (C2)

' ─────────────────────────────────────────
' RELACIONES — Repositories → ApiClient y Mappers
' ─────────────────────────────────────────

LevelRepositoryImpl        --> ApiClient      : uses
LevelRepositoryImpl        --> LevelMapper    : uses
GameProgressRepositoryImpl --> ApiClient      : uses
GameProgressRepositoryImpl --> ProgressMapper : uses
AuthRepositoryImpl         --> ApiClient      : uses
LeaderboardRepositoryImpl  --> ApiClient      : uses

@enduml
