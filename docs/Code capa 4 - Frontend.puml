BoardEditorScreen *-- "0..1" _EditorGridPainter : uses

' ─────────────────────────────────────────
' WIDGETS — Tablero y flechas
' ─────────────────────────────────────────

class ArrowPainter <<CustomPainter>> {
  + direction: Direction
  + color: Color
  + cellSize: double
  + isActivatable: bool
  --
  + paint(canvas: Canvas, size: Size): void
  - _paintZAxisMarker(canvas: Canvas, size: Size): void
  + shouldRepaint(oldDelegate: ArrowPainter): bool
}

note right of ArrowPainter
  Dibuja cuerpo + cabeza triangular de
  una flecha. Direcciones Z (juego 3D)
  se pintan como marcador ⊙/⊗ en vez
  de flecha plana.
end note

class BoardPainter <<CustomPainter>> {
  + board: Board
  + activatableArrows: Set<String>
  + flashMap: Map<String, FlashType>
  + cellSize: double
  + minX: int
  + minY: int
  + exitingArrows: List<ExitingArrowAnim>?
  + highlightArrowId: String?
  + highlightPulse: double
  + gridOverlayOpacity: double
  + smashingArrows: List<SmashingArrowAnim>?
  - projection: BoardProjection
  --
  + paint(canvas: Canvas, size: Size): void
  - _drawPrismFaces(canvas: Canvas): void
  - _drawArrow(canvas, arrow, color, alpha, flash): void
  - _drawHintRing(canvas: Canvas): void
  - _drawExitLines(canvas: Canvas): void
  - _drawSmashingArrows(canvas: Canvas): void
  + shouldRepaint(oldDelegate: BoardPainter): bool
}

note right of BoardPainter
  Renderer 2D/plano por defecto — pinta
  celdas, flechas, animación de salida
  (worm-exit), caras laterales del prisma
  (tableros 3D con perspectiva, no ditredi)
  y overlays de los 3 power-ups.
end note

class ExitingArrowAnim {
  + cells: List<Position>
  + direction: Direction
  + color: String
  + edgeDistance: int
  + progress: double
}

class SmashingArrowAnim {
  + cells: List<Position>
  + direction: Direction
  + color: String
  + progress: double
}

class BoardProjection {
  + {static} depthStep: double
  + cellSize: double
  + minX: int
  + minY: int
  + maxZ: int
  --
  + centerOf(pos: Position): Offset
  + centerOfXYZf(gx: double, gy: double, z: double): Offset
  + canvasSize(cols: int, rows: int): Size
  + cellAt(local: Offset, z: int): Position?
  + screenVector(dx: int, dy: int, dz: int): (double, double)
}

note right of BoardProjection
  Fuente única de verdad para cell(x,y,z)
  → píxel (proyección "cascada" en capas
  diagonales). Compartida por BoardPainter
  (dibujo) y GameScreen (hit-testing de
  toques) — lo que se ve es lo que se toca.
end note

class Board3DEngineView <<StatefulWidget>> {
  + board: Board
  + activatableArrows: Set<String>
  + onArrowTapped: Function(String)
  + cols: int
  + rows: int
  + exitingArrows: List<ExitingArrowAnim>
  + highlightArrowId: String?
  + gridOverlayOpacity: double
  + smashingArrows: List<SmashingArrowAnim>
  - _controller: DiTreDiController
  - _smoothPath(points: List<Vector3>): List<Vector3>
  - _drawArrowModel(models, rawPoints, color, dir): void
  - _drawHintGizmo(models, bodyPoints): void
  - _buildScene(): List<Model3D>
  - _handleTap(localPosition: Offset, canvasSize: Size): void
  --
  + build(context: BuildContext): Widget
}

note right of Board3DEngineView
  Renderizado 3D matemático real (paquete
  ditredi, C4) para el "Juego 3D (6
  direcciones)": pirámides como cabezas de
  flecha, líneas suavizadas en las esquinas,
  hit-testing por proyección de la matriz
  de cámara. Independiente del modo
  "Tablero 3D" (perspectiva, BoardPainter).
end note

class BoardShapePreview <<StatelessWidget>> {
  + grid: List<List<int>>
  + size: double
  + activeColor: Color
  --
  + build(context: BuildContext): Widget
}

class _ShapeDotsPainter <<CustomPainter>> {
  + grid: List<List<int>>
  + activeColor: Color
  --
  + paint(canvas: Canvas, size: Size): void
  + shouldRepaint(oldDelegate): bool
}

note right of BoardShapePreview
  Preview barato de una FORMA (puntos,
  sin flechas ni generación) para listas
  de tableros de la comunidad — envuelto
  en RepaintBoundary.
end note

BoardShapePreview *-- "1" _ShapeDotsPainter : uses
BoardPainter *-- "1" BoardProjection : projection
BoardPainter ..> ExitingArrowAnim  : uses
