  - _pendingSmashes: Map<String, _PendingSmash>
  - _transformationController: TransformationController
  - _loadLevel(): void
  - _startExitAnimation(arrow: Arrow, shape: BoardShape): void
  - _startSmashAnimation(arrow: Arrow): void
  - _startHintAnimation(arrowId: String): void
  - _startGridOverlayAnimation(): void
  - _onPowerUpSelected(type: String, ...): Future<void>
  - _confirmExit({onConfirmed: VoidCallback}): void
  --
  + build(): Widget
  - _buildBody(gameState: GameState, gameNotifier: GameNotifier, l10n: AppLocalizations, board3D: bool): Widget
  - _buildPauseOverlay(gameNotifier: GameNotifier): Widget
}

note right of GameScreen
  El widget más complejo. Orquesta:
  - BoardPainter (2D) o Board3DEngineView (3D,
    toggle "Juego 3D" de Configuración)
  - Animaciones de salida (worm-exit),
    martillo (smash) e hint/grid power-up
  - PowerUpBar y confirmación de salida
    (cuenta como derrota, pide confirmar)
  - Navega a VictoryScreen/DefeatScreen
    según el estado de GameSession.
end note

