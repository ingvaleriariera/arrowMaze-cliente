@startuml client_layer4_frameworks
title Arrow Maze Cliente — Capa 4: Frameworks & UI

skinparam backgroundColor #FFFFFF
skinparam class {
  BackgroundColor #FFF8E1
  BorderColor #E65100
  HeaderBackgroundColor #F57C00
  HeaderFontColor #FFFFFF
  FontColor #000000
  ArrowColor #333333
}
skinparam note {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

note as N1
  Capa más externa. Contiene:
  1. Widgets Flutter (Screens) — la UI.
     Observan StateNotifiers de C3.
  2. AOP — Interceptores de Dio:
     logging, auth y errores.
  3. Configuración del framework:
     enrutamiento, i18n, Riverpod root.
  4. Frameworks externos (sqflite, Dio,
     flutter_secure_storage, just_audio).
end note

' ─────────────────────────────────────────
' AOP — INTERCEPTORES DIO
' ─────────────────────────────────────────

class AuthInterceptor <<AOP-Auth>> {
  - authRepository: IAuthRepository
  --
  + onRequest(options: RequestOptions): void
  + onError(error: DioError): void
}

class LoggingInterceptor <<AOP-Logging>> {
  --
  + onRequest(options: RequestOptions): void
  + onResponse(response: Response): void
  + onError(error: DioError): void
}

class ErrorInterceptor <<AOP-Exception>> {
  --
  + onError(error: DioError): void
}

note right of AuthInterceptor
  Patrón AOP (Aspecto de Seguridad).
  onRequest() → inyecta el JWT header
  en cada request automáticamente.
  onError() → si recibe 401, limpia
  la sesión y redirige al login.
end note

note right of LoggingInterceptor
  Patrón AOP (Aspecto de Logging).
  Registra request/response/error
  de cada llamada HTTP.
  Solo activo en modo debug.
end note

note right of ErrorInterceptor
  Patrón AOP (Aspecto de Excepciones).
  Convierte errores HTTP (400, 404, 500,
  timeout, sin conexión) en excepciones
  tipadas que los notifiers manejan.
end note

' ─────────────────────────────────────────
' CONFIGURACIÓN — App entry point
' ─────────────────────────────────────────

class MyApp {
  --
  + build(): Widget
}

class AppRouter {
  --
  + {static} routes: List<RouteBase>
  + {static} navigateTo(route: String): void
  + {static} replace(route: String): void
}

class AppLocalizations {
  --
  + {static} of(context: BuildContext): AppLocalizations
  + gameTitle(): String
  + levelSelect(): String
  + victory(): String
  + defeat(): String
  + retry(): String
  + moves(): String
  + score(): String
}

note right of AppLocalizations
  i18n — soporte mínimo español + inglés
  (requisito del enunciado).
  Usa flutter_localizations (C4).
end note

' ─────────────────────────────────────────
' SCREENS — Widgets Flutter
' ─────────────────────────────────────────

class SplashScreen {
  - authNotifier: AuthNotifier
  --
  + build(): Widget
}

note right of SplashScreen
  Verifica si hay sesión activa.
  Redirige a LevelSelectScreen
  o LoginScreen según el estado
  de AuthNotifier.
end note

class LoginScreen {
  - authNotifier: AuthNotifier
  --
  + build(): Widget
  - onLogin(email: String, password: String): void
  - onNavigateToRegister(): void
}

class RegisterScreen {
  - authNotifier: AuthNotifier
  --
  + build(): Widget
  - onRegister(email: String, username: String, password: String): void
}

class LevelSelectScreen {
  - levelSelectNotifier: LevelSelectNotifier
  - authNotifier: AuthNotifier
  --
  + build(): Widget
  - onSelectLevel(levelId: String): void
  - onNavigateToSettings(): void
  - onNavigateToLeaderboard(): void
}

class GameScreen {
  - gameNotifier: GameNotifier
  --
  + build(): Widget
  - onTapArrow(arrowId: String): void
  - onTapHint(): void
  - onTapHammer(arrowId: String): void
  - onTapMagnet(direction: Direction): void
  - onPause(): void
}

note right of GameScreen
  El widget más complejo.
  Observa GameNotifier para:
  - Dibujar el tablero y las flechas
  - Mostrar score, moves, timer
  - Animación de salida de flechas
  - Navegar a VictoryScreen/DefeatScreen
    cuando GameSession cambia de estado.
end note

class VictoryScreen {
  - gameNotifier: GameNotifier
  --
  + build(): Widget
  - onNextLevel(): void
  - onBackToMenu(): void
}

class DefeatScreen {
  - gameNotifier: GameNotifier
  --
  + build(): Widget
  - onRetry(): void
  - onBackToMenu(): void
}

class LeaderboardScreen {
  - leaderboardNotifier: LeaderboardNotifier
  --
  + build(): Widget
  - onSelectLevel(levelId: String): void
}

class SettingsScreen {
  - settingsNotifier: SettingsNotifier
  --
  + build(): Widget
  - onToggleMute(): void
  - onSelectLanguage(locale: String): void
}

' ─────────────────────────────────────────
' FRAMEWORKS EXTERNOS
' (no se detallan — son dependencias externas)
' ─────────────────────────────────────────

note as N2
  Frameworks externos usados por C3:
  ─────────────────────────────────
  Dio               → ApiClient (HTTP)
  sqflite           → GameProgressRepositoryImpl (local DB)
  flutter_secure_storage → AuthRepositoryImpl (JWT storage)
  just_audio        → AudioServiceImpl (sonido)
  flutter_localizations  → AppLocalizations (i18n)
  dart:async Timer  → GameNotifier (cronómetro)
end note

' ─────────────────────────────────────────
' RELACIONES
' ─────────────────────────────────────────

' App setup
MyApp --> AppRouter       : configures
MyApp --> AppLocalizations : configures

' AOP — Interceptors componen el ApiClient (C3)
AuthInterceptor   --> ApiClient : configures (C3)
LoggingInterceptor --> ApiClient : configures (C3)
ErrorInterceptor  --> ApiClient : configures (C3)
AuthInterceptor   --> IAuthRepository : uses (C2)

' Screens → Notifiers (C3)
SplashScreen     --> AuthNotifier        : observes (C3)
LoginScreen      --> AuthNotifier        : observes (C3)
RegisterScreen   --> AuthNotifier        : observes (C3)
LevelSelectScreen --> LevelSelectNotifier : observes (C3)
LevelSelectScreen --> AuthNotifier       : observes (C3)
GameScreen       --> GameNotifier        : observes (C3)
VictoryScreen    --> GameNotifier        : observes (C3)
DefeatScreen     --> GameNotifier        : observes (C3)
LeaderboardScreen --> LeaderboardNotifier : observes (C3)
SettingsScreen   --> SettingsNotifier    : observes (C3)

' Screens → Router
SplashScreen      --> AppRouter : uses
LevelSelectScreen --> AppRouter : uses
VictoryScreen     --> AppRouter : uses
DefeatScreen      --> AppRouter : uses

@enduml
